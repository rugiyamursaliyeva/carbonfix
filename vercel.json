{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/server.js"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "/backend/uploads/$1"
        },
        {
            "source": "/admin(.*)",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/login(.*)",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/admin-login(.*)",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/((?!api|uploads).*)",
            "destination": "/frontend/index.html"
        }
    ]
}