{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://carbonfix-production.up.railway.app/api/$1"
        },
        {
            "source": "/product(.*)",
            "destination": "https://carbonfix-production.up.railway.app/product$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://carbonfix-production.up.railway.app/uploads/$1"
        },
        {
            "source": "/admin(.*)",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/login(.*)",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/admin-login(.*)",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/((?!api|uploads).*)",
            "destination": "/frontend/index.html"
        }
    ]
}