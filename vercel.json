{
    "rewrites": [
        {
            "source": "/admin(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/admin-login(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/login(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/((?!api|uploads).*)",
            "destination": "/index.html"
        }
    ]
}